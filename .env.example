# At least one API key is required
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROK_API_KEY=

# Optional configuration
BRMONK_MODEL=claude-sonnet-4-20250514
BRMONK_HEADLESS=true
BRMONK_MEMORY_DIR=~/.brmonk
BRMONK_SKILLS_DIR=~/.brmonk/skills

# ── Docker / Remote Browser ──────────────────────────────────────
# Browser backend: playwright | playwright-mcp | remote-cdp | remote-mcp
# BRMONK_BROWSER_BACKEND=remote-cdp

# Remote CDP: Chrome on host with --remote-debugging-port=9222
# BRMONK_CDP_URL=http://host.docker.internal:9222

# Remote MCP: Playwright MCP server on host with --port 3100
# BRMONK_MCP_URL=http://host.docker.internal:3100/mcp
